{
  "manifest_version": 3,
  "name": "Threads Auto Reveal",
  "version": "1.3.0",
  "description": "Auto-reveal hidden spoilers on Threads (text, images & videos)",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
