{
  "manifest_version": 3,
  "name": "Threads Auto Reveal",
  "version": "2.0.3",
  "description": "Auto-reveal hidden spoilers on Threads (text & media), and enable video controls.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}