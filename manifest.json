{
  "manifest_version": 3,
  "name": "Threads Auto Reveal",
  "version": "2.2.2",
  "description": "Auto-reveal hidden spoilers on Threads (text & media), and enable video controls.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.com/*"
      ],
      "js": [
        "src/common.js",
        "src/sites/threads.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/common.js",
        "src/sites/instagram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/*"
      ],
      "js": [
        "src/common.js",
        "src/sites/facebook.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
